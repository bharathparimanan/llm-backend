# ─────────────────────────────────────────────────────────────────────────────
# foundation-ai — environment variable reference
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=foundation-ai
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required.  Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# ── Generation defaults ───────────────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1024

# ── Logging ───────────────────────────────────────────────────────────────────
# Set LOG_JSON=true in staging/production for structured log aggregation.
LOG_LEVEL=INFO
LOG_JSON=false

# ─────────────────────────────────────────────────────────────────────────────
# FUTURE UPGRADE additions (uncomment when the corresponding module is active):
# ─────────────────────────────────────────────────────────────────────────────

# Database (Module 2+)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foundation_ai

# Redis cache (Module 2+)
# REDIS_URL=redis://localhost:6379/0

# Vector store (Module 4 — RAG)
# VECTOR_STORE_URL=postgresql+asyncpg://user:password@localhost:5432/foundation_ai
# VECTOR_STORE_COLLECTION=documents

# Anthropic (Module 2 — multi-provider)
# ANTHROPIC_API_KEY=sk-ant-...
